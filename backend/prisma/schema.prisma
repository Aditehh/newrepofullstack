generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  notes    Note[]
}

model Note {
  id           String   @id @default(cuid())
  title        String
  content      String
  createdAt    DateTime @default(now())
  filePublicId String?
  userId       String
  file         String?
  user         User     @relation(fields: [userId], references: [id])
}
